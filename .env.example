# Groq API — required for AI Data Analyst (NL→SQL + summarization)
# Obtain a key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional model overrides (defaults match assignment spec)
GROQ_NL2SQL_MODEL=llama-3.3-70b-versatile
GROQ_SUMMARY_MODEL=llama-3.3-70b-versatile

# Portfolio CSV path (optional — defaults to data/application_train.csv)
# CREDIT_RISK_PORTFOLIO_CSV=data/application_train.csv

# FastAPI URL for Risk Prediction / Decision Rules (optional)
# CREDIT_RISK_API_URL=http://127.0.0.1:8000
